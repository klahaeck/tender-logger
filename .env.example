# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://APPLICATION_USER:STRONG_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=parenting_log

# Clerk invitation-only authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app
# Comma-separated paid Clerk user Plan slugs accepted for workspace access.
# The hidden default Free plan is intentionally excluded.
CLERK_ALLOWED_PLAN_SLUGS=general

# Vercel Private Blob — configure either a token or OIDC/store pair
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_REPLACE_ME
# BLOB_STORE_ID=store_REPLACE_ME
# VERCEL_OIDC_TOKEN is supplied automatically by Vercel when OIDC is enabled.

# Optional integration-test database; never point this at production
TEST_MONGODB_URI=mongodb://127.0.0.1:27017
